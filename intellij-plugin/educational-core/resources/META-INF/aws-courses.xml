<!--suppress PluginXmlValidity -->
<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <experimentalFeature id="edu.course.aws" percentOfUsers="100" internalFeature="true">
      <description>Enables AWS courses support</description>
    </experimentalFeature>
  </extensions>
  <actions>
    <action id="Educational.StartAWSCourse" class="com.jetbrains.edu.learning.marketplace.awsTracks.course.StartAWSCourseAction" internal="true"/>
    <action id="Educational.Student.AWSTracksServiceChangeHost"
            class="com.jetbrains.edu.learning.marketplace.awsTracks.changeHost.AWSTracksServiceChangeHost"
            internal="true"/>
  </actions>
</idea-plugin>